{
  "manifest_version": 3,
  "name": "NextLevel Web Clipper",
  "version": "1.0",
  "description": "Instantly save links, notes, and highlights to your NextLevel AI Vault.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://your-production-url.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
